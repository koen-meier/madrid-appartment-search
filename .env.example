# Supabase — Settings > API in the Supabase dashboard
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (never expose this in the dashboard)
SUPABASE_ANON_KEY=eyJ...      # anon key (safe to embed in the dashboard HTML)

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=madrid-search@yourdomain.com   # must be a verified domain in Resend
EMAIL_TO=you@gmail.com

# Apify — https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_...     # needed for Idealista scraping
